{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vallnews.local/schemas/rich-response.schema.json",
  "title": "VALL-AI Rich Response",
  "type": "object",
  "required": ["type", "version", "title", "mode", "blocks"],
  "additionalProperties": false,
  "properties": {
    "type": { "const": "rich_response" },
    "version": { "const": "1.0" },
    "title": { "type": "string", "maxLength": 240 },
    "summary": { "type": "string", "maxLength": 1600 },
    "mode": { "enum": ["quick", "normal", "detailed", "technical", "executive"] },
    "markdown": { "type": "string", "maxLength": 50000 },
    "blocks": {
      "type": "array",
      "minItems": 1,
      "maxItems": 40,
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {
            "enum": ["text", "heading", "markdown", "code", "table", "diagram", "chart", "image", "quote", "alert", "steps", "checklist", "comparison", "formula", "document", "download"]
          }
        }
      }
    },
    "meta": {
      "type": "object",
      "properties": {
        "provider": { "type": "string" },
        "model": { "type": "string" },
        "taskType": { "type": "string" },
        "generatedAt": { "type": "string", "format": "date-time" },
        "latencyMs": { "type": "number", "minimum": 0 },
        "warnings": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
