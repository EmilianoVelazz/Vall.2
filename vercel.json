{
  "version": 2,
  "redirects": [
    { "source": "/inicio",            "destination": "/inicio.html",                              "permanent": false },
    { "source": "/finanzas",          "destination": "/finanzas/finanzas.html",                   "permanent": false },
    { "source": "/mercados",          "destination": "/mercados/mercados.html",                   "permanent": false },
    { "source": "/geopolitica",       "destination": "/geopolitica/geopolitica.html",             "permanent": false },
    { "source": "/mexico",            "destination": "/mexico/mexico.html",                       "permanent": false },
    { "source": "/mercado-proteinas", "destination": "/mercado_proteinas/mercadoproteinas.html",  "permanent": false },
    { "source": "/configuracion",     "destination": "/configuracion/configuracion.html",         "permanent": false }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.js" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/js/(.*)\\.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/css/(.*)\\.css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
